@page "/admin/layout"
@rendermode InteractiveServer
@using KennelTrace.Domain.Features.Locations
@using KennelTrace.Infrastructure.Features.Facilities.FacilityMap
@using KennelTrace.Web.Features.Facilities.Admin
@using KennelTrace.Web.Features.Locations.Admin
@using KennelTrace.Web.Security
@attribute [Authorize(Roles = KennelTraceRoles.Admin)]
@inject IFacilityAdminService FacilityAdminService
@inject IFacilityMapReadService FacilityMapReadService
@inject ILocationAdminService LocationAdminService
@inject ILocationLinkAdminService LocationLinkAdminService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Layout Admin</PageTitle>

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 data-testid="admin-layout-page">Layout Admin</h1>
        <p class="text-muted mb-0">Maintain facilities, containment structure, kennel placement, and explicit stored links here.</p>
    </div>
    <button type="button" class="btn btn-outline-primary" data-testid="new-facility-button" @onclick="StartCreate">
        New Facility
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(_facilitySaveErrorMessage))
{
    <div class="alert alert-danger" role="alert" data-testid="facility-save-error">@_facilitySaveErrorMessage</div>
}

<div class="row g-4">
    <section class="col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h2 class="h5 mb-0">Facilities</h2>
            </div>
            <div class="card-body">
                @if (_facilities.Count == 0)
                {
                    <p class="text-muted mb-0">No facilities have been created yet.</p>
                }
                else
                {
                    <div class="list-group" data-testid="facility-list">
                        @foreach (var facility in _facilities)
                        {
                            <button type="button"
                                    class="@GetFacilityListButtonCssClass(facility)"
                                    data-testid="@($"facility-list-item-{facility.FacilityId}")"
                                    @onclick="@(() => SelectFacilityAsync(facility))">
                                <div class="d-flex w-100 justify-content-between">
                                    <strong>@facility.Name</strong>
                                    <span class="badge text-bg-@(facility.IsActive ? "success" : "secondary")">
                                        @(facility.IsActive ? "Active" : "Inactive")
                                    </span>
                                </div>
                                <div>@facility.FacilityCode</div>
                                <small class="text-muted">@facility.TimeZoneId</small>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header">
                <h2 class="h5 mb-0">@(_facilityModel.FacilityId.HasValue ? "Edit Facility" : "Create Facility")</h2>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label" for="facility-code">Facility Code</label>
                    <input id="facility-code"
                           class="form-control"
                           data-testid="facility-code-input"
                           @bind="_facilityModel.FacilityCode" />
                    @RenderFieldError(_facilityFieldErrors, nameof(FacilitySaveRequest.FacilityCode))
                </div>

                <div class="mb-3">
                    <label class="form-label" for="facility-name">Name</label>
                    <input id="facility-name"
                           class="form-control"
                           data-testid="facility-name-input"
                           @bind="_facilityModel.Name" />
                    @RenderFieldError(_facilityFieldErrors, nameof(FacilitySaveRequest.Name))
                </div>

                <div class="mb-3">
                    <label class="form-label" for="facility-timezone">Time Zone</label>
                    <input id="facility-timezone"
                           class="form-control"
                           data-testid="facility-timezone-input"
                           @bind="_facilityModel.TimeZoneId" />
                    @RenderFieldError(_facilityFieldErrors, nameof(FacilitySaveRequest.TimeZoneId))
                </div>

                <div class="form-check mb-3">
                    <input id="facility-active"
                           class="form-check-input"
                           type="checkbox"
                           data-testid="facility-active-input"
                           @bind="_facilityModel.IsActive" />
                    <label class="form-check-label" for="facility-active">Active</label>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="facility-notes">Notes</label>
                    <textarea id="facility-notes"
                              class="form-control"
                              rows="4"
                              data-testid="facility-notes-input"
                              @bind="_facilityModel.Notes"></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-primary" data-testid="facility-save-button" @onclick="SaveFacilityAsync">
                        Save Facility
                    </button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="ResetFacilityForm">
                        Reset
                    </button>
                </div>
            </div>
        </div>
    </section>
</div>

<section class="card shadow-sm mt-4">
    <div class="card-header d-flex flex-wrap justify-content-between align-items-end gap-3">
        <div>
            <h2 class="h5 mb-1">Locations</h2>
            <p class="text-muted mb-0">Browse facility structure and create, edit, or deactivate room-like spaces and kennels.</p>
        </div>
        <div class="d-flex flex-wrap align-items-end gap-2">
            <div>
                <label class="form-label mb-1" for="location-facility-select">Facility</label>
                <select id="location-facility-select"
                        class="form-select"
                        data-testid="location-facility-select"
                        value="@(_selectedLocationFacilityId?.ToString() ?? string.Empty)"
                        @onchange="OnLocationFacilityChanged">
                    @if (_facilities.Count == 0)
                    {
                        <option value="">No facilities</option>
                    }
                    else
                    {
                        @foreach (var facility in _facilities)
                        {
                            <option value="@facility.FacilityId">
                                @facility.Name (@facility.FacilityCode)
                            </option>
                        }
                    }
                </select>
            </div>
            <button type="button"
                    class="btn btn-outline-primary"
                    data-testid="new-location-button"
                    disabled="@(!_selectedLocationFacilityId.HasValue)"
                    @onclick="StartCreateLocation">
                New Location
            </button>
            <button type="button"
                    class="btn btn-outline-secondary"
                    data-testid="new-child-location-button"
                    disabled="@(!CanCreateChildLocation())"
                    @onclick="StartCreateChildLocation">
                New Child
            </button>
        </div>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrWhiteSpace(_locationSaveErrorMessage))
        {
            <div class="alert alert-danger" role="alert" data-testid="location-save-error">@_locationSaveErrorMessage</div>
        }

        @if (_selectedLocationFacilityId is null || _locationView is null)
        {
            <p class="text-muted mb-0">Select or create a facility to manage its containment structure.</p>
        }
        else
        {
            <div class="row g-4">
                <section class="col-lg-5">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
                            <div>
                                <div class="fw-semibold">@_locationView.FacilityName</div>
                                <div class="text-muted small">@_locationView.FacilityCode</div>
                            </div>
                            <span class="badge text-bg-@(_locationView.IsActive ? "success" : "secondary")">
                                @(_locationView.IsActive ? "Facility Active" : "Facility Inactive")
                            </span>
                        </div>

                        @if (_locationView.RootLocations.Count == 0)
                        {
                            <p class="text-muted mb-0" data-testid="location-empty-state">No locations have been created for this facility yet.</p>
                        }
                        else
                        {
                            <div data-testid="location-browser-tree">
                                @foreach (var root in _locationView.RootLocations)
                                {
                                    @RenderLocationNode(root)
                                }
                            </div>
                        }
                    </div>
                </section>

                <section class="col-lg-7">
                    <div class="border rounded p-3" data-testid="location-form">
                        <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
                            <h3 class="h5 mb-0">@(_locationModel.LocationId.HasValue ? "Edit Location" : "Create Location")</h3>
                            @if (_selectedLocationId.HasValue)
                            {
                                <span class="badge text-bg-@(_locationModel.IsActive ? "success" : "secondary")">
                                    @(_locationModel.IsActive ? "Active" : "Inactive")
                                </span>
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="location-type-input">Location Type</label>
                            <select id="location-type-input"
                                    class="form-select"
                                    data-testid="location-type-input"
                                    value="@_locationModel.LocationType.ToString()"
                                    @onchange="OnLocationTypeChanged">
                                @foreach (var locationType in Enum.GetValues<LocationType>())
                                {
                                    <option value="@locationType">@locationType</option>
                                }
                            </select>
                            @RenderFieldError(_locationFieldErrors, nameof(LocationSaveRequest.LocationType))
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="location-code-input">Location Code</label>
                            <input id="location-code-input"
                                   class="form-control"
                                   data-testid="location-code-input"
                                   @bind="_locationModel.LocationCode" />
                            @RenderFieldError(_locationFieldErrors, nameof(LocationSaveRequest.LocationCode))
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="location-name-input">Name</label>
                            <input id="location-name-input"
                                   class="form-control"
                                   data-testid="location-name-input"
                                   @bind="_locationModel.Name" />
                            @RenderFieldError(_locationFieldErrors, nameof(LocationSaveRequest.Name))
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="parent-location-input">Parent Location</label>
                            <select id="parent-location-input"
                                    class="form-select"
                                    data-testid="parent-location-input"
                                    value="@(_locationModel.ParentLocationId?.ToString() ?? string.Empty)"
                                    @onchange="OnParentLocationChanged">
                                @if (LocationTypeRules.CanAppearAtFacilityRoot(_locationModel.LocationType))
                                {
                                    <option value="">No parent (facility root)</option>
                                }
                                else
                                {
                                    <option value="">Select a parent</option>
                                }

                                @foreach (var parentOption in GetAvailableParentLocations())
                                {
                                    <option value="@parentOption.LocationId">
                                        @parentOption.Name (@parentOption.LocationCode) - @parentOption.LocationType
                                    </option>
                                }
                            </select>
                            @RenderFieldError(_locationFieldErrors, nameof(LocationSaveRequest.ParentLocationId))
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="display-order-input">Display Order</label>
                            <input id="display-order-input"
                                   type="number"
                                   class="form-control"
                                   data-testid="display-order-input"
                                   @bind="_locationModel.DisplayOrderText" />
                            @RenderFieldError(_locationFieldErrors, nameof(LocationSaveRequest.DisplayOrder))
                        </div>

                        @if (_locationModel.LocationType == LocationType.Kennel)
                        {
                            <div class="row g-3 mb-3">
                                <div class="col-sm-4">
                                    <label class="form-label" for="grid-row-input">Grid Row</label>
                                    <input id="grid-row-input"
                                           type="number"
                                           class="form-control"
                                           data-testid="grid-row-input"
                                           @bind="_locationModel.GridRowText" />
                                    @RenderFieldError(_locationFieldErrors, nameof(LocationSaveRequest.GridRow))
                                </div>
                                <div class="col-sm-4">
                                    <label class="form-label" for="grid-column-input">Grid Column</label>
                                    <input id="grid-column-input"
                                           type="number"
                                           class="form-control"
                                           data-testid="grid-column-input"
                                           @bind="_locationModel.GridColumnText" />
                                    @RenderFieldError(_locationFieldErrors, nameof(LocationSaveRequest.GridColumn))
                                </div>
                                <div class="col-sm-4">
                                    <label class="form-label" for="stack-level-input">Stack Level</label>
                                    <input id="stack-level-input"
                                           type="number"
                                           class="form-control"
                                           data-testid="stack-level-input"
                                           @bind="_locationModel.StackLevelText" />
                                    @RenderFieldError(_locationFieldErrors, nameof(LocationSaveRequest.StackLevel))
                                </div>
                            </div>
                        }

                        <div class="form-check mb-3">
                            <input id="location-active-input"
                                   class="form-check-input"
                                   type="checkbox"
                                   data-testid="location-active-input"
                                   @bind="_locationModel.IsActive" />
                            <label class="form-check-label" for="location-active-input">Active</label>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="location-notes-input">Notes</label>
                            <textarea id="location-notes-input"
                                      class="form-control"
                                      rows="4"
                                      data-testid="location-notes-input"
                                      @bind="_locationModel.Notes"></textarea>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-primary" data-testid="location-save-button" @onclick="SaveLocationAsync">
                                Save Location
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="ResetLocationForm">
                                Reset
                            </button>
                        </div>
                    </div>

                    @if (SelectedLocationCanManageLinks())
                    {
                        <div class="border rounded p-3 mt-4" data-testid="location-links-panel">
                            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                                <div>
                                    <h3 class="h5 mb-1">Explicit Links</h3>
                                    <p class="text-muted mb-0">Manage stored adjacency and topology links for the selected location. Grid coordinates remain a display aid only.</p>
                                </div>
                                <div class="d-flex gap-2">
                                    <button type="button"
                                            class="btn btn-outline-primary"
                                            data-testid="add-outgoing-link-button"
                                            @onclick="@(() => OpenCreateLinkDialog(LinkDialogDirection.Outgoing))">
                                        Add Outgoing Link
                                    </button>
                                    <button type="button"
                                            class="btn btn-outline-secondary"
                                            data-testid="add-incoming-link-button"
                                            @onclick="@(() => OpenCreateLinkDialog(LinkDialogDirection.Incoming))">
                                        Add Incoming Link
                                    </button>
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_linkSaveErrorMessage))
                            {
                                <div class="alert alert-danger" role="alert" data-testid="link-save-error">@_linkSaveErrorMessage</div>
                            }

                            <div class="row g-4">
                                <section class="col-xl-6">
                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle mb-0" data-testid="outgoing-links-table">
                                            <thead>
                                                <tr>
                                                    <th scope="col">Type</th>
                                                    <th scope="col">Target</th>
                                                    <th scope="col">Source Type</th>
                                                    <th scope="col">Notes</th>
                                                    <th scope="col"></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (GetOutgoingLinks().Count == 0)
                                                {
                                                    <tr>
                                                        <td colspan="5" class="text-muted" data-testid="outgoing-links-empty">No active outgoing links are stored for this location.</td>
                                                    </tr>
                                                }
                                                else
                                                {
                                                    @foreach (var link in GetOutgoingLinks())
                                                    {
                                                        <tr data-testid="@($"outgoing-link-row-{link.LocationLinkId}")">
                                                            <td>@link.LinkType</td>
                                                            <td>
                                                                <div class="fw-semibold">@link.ToLocationName</div>
                                                                <div class="text-muted small">@link.ToLocationCode · @link.ToLocationType</div>
                                                            </td>
                                                            <td>@link.SourceType</td>
                                                            <td>
                                                                @if (!string.IsNullOrWhiteSpace(link.SourceReference))
                                                                {
                                                                    <div class="small">Ref: @link.SourceReference</div>
                                                                }
                                                                @if (!string.IsNullOrWhiteSpace(link.Notes))
                                                                {
                                                                    <div class="small text-muted">@link.Notes</div>
                                                                }
                                                            </td>
                                                            <td class="text-end">
                                                                <button type="button"
                                                                        class="btn btn-sm btn-outline-danger"
                                                                        data-testid="@($"remove-link-button-{link.LocationLinkId}")"
                                                                        @onclick="@(() => OpenRemoveLinkDialog(link))">
                                                                    Remove
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </section>

                                <section class="col-xl-6">
                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle mb-0" data-testid="incoming-links-table">
                                            <thead>
                                                <tr>
                                                    <th scope="col">Type</th>
                                                    <th scope="col">Source</th>
                                                    <th scope="col">Source Type</th>
                                                    <th scope="col">Notes</th>
                                                    <th scope="col"></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (GetIncomingLinks().Count == 0)
                                                {
                                                    <tr>
                                                        <td colspan="5" class="text-muted" data-testid="incoming-links-empty">No active incoming links are stored for this location.</td>
                                                    </tr>
                                                }
                                                else
                                                {
                                                    @foreach (var link in GetIncomingLinks())
                                                    {
                                                        <tr data-testid="@($"incoming-link-row-{link.LocationLinkId}")">
                                                            <td>@link.LinkType</td>
                                                            <td>
                                                                <div class="fw-semibold">@link.FromLocationName</div>
                                                                <div class="text-muted small">@link.FromLocationCode · @link.FromLocationType</div>
                                                            </td>
                                                            <td>@link.SourceType</td>
                                                            <td>
                                                                @if (!string.IsNullOrWhiteSpace(link.SourceReference))
                                                                {
                                                                    <div class="small">Ref: @link.SourceReference</div>
                                                                }
                                                                @if (!string.IsNullOrWhiteSpace(link.Notes))
                                                                {
                                                                    <div class="small text-muted">@link.Notes</div>
                                                                }
                                                            </td>
                                                            <td class="text-end">
                                                                <button type="button"
                                                                        class="btn btn-sm btn-outline-danger"
                                                                        data-testid="@($"remove-link-button-{link.LocationLinkId}")"
                                                                        @onclick="@(() => OpenRemoveLinkDialog(link))">
                                                                    Remove
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </section>
                            </div>
                        </div>
                    }

                    @if (SelectedLocationCanManagePlacement())
                    {
                        <div class="border rounded p-3 mt-4" data-testid="room-placement-editor">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <div>
                                    <h3 class="h5 mb-1">Kennel Placement</h3>
                                    <p class="text-muted mb-0">Edit kennel row, column, stack, and display order for the selected room. Coordinates are a display aid only and do not create adjacency.</p>
                                </div>
                                @if (_selectedRoomMap is not null)
                                {
                                    <div class="small text-muted text-end">
                                        <div>@_selectedRoomMap.PlacedLocations.Count placed</div>
                                        <div>@_selectedRoomMap.UnplacedLocations.Count unplaced</div>
                                    </div>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_roomPlacementSaveErrorMessage))
                            {
                                <div class="alert alert-danger" role="alert" data-testid="room-placement-error">@_roomPlacementSaveErrorMessage</div>
                            }

                            @if (_roomPlacementRows.Count == 0)
                            {
                                <p class="text-muted mb-0" data-testid="room-placement-empty">No kennel children are available for this room yet.</p>
                            }
                            else
                            {
                                <div class="table-responsive mb-4">
                                    <table class="table table-sm align-middle" data-testid="room-placement-table">
                                        <thead>
                                            <tr>
                                                <th scope="col">Kennel</th>
                                                <th scope="col">Status</th>
                                                <th scope="col">Grid Row</th>
                                                <th scope="col">Grid Column</th>
                                                <th scope="col">Stack Level</th>
                                                <th scope="col">Display Order</th>
                                                <th scope="col"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in _roomPlacementRows)
                                            {
                                                <tr data-testid="@($"placement-row-{row.LocationId}")">
                                                    <td>
                                                        <div class="fw-semibold">@row.Name</div>
                                                        <div class="text-muted small">@row.LocationCode</div>
                                                    </td>
                                                    <td>
                                                        <span class="badge text-bg-@(row.IsActive ? "success" : "secondary")">
                                                            @(row.IsActive ? "Active" : "Inactive")
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <input type="number"
                                                               class="form-control form-control-sm"
                                                               data-testid="@($"placement-grid-row-{row.LocationId}")"
                                                               @bind="row.GridRowText" />
                                                        @RenderFieldError(row.FieldErrors, nameof(LocationSaveRequest.GridRow))
                                                    </td>
                                                    <td>
                                                        <input type="number"
                                                               class="form-control form-control-sm"
                                                               data-testid="@($"placement-grid-column-{row.LocationId}")"
                                                               @bind="row.GridColumnText" />
                                                        @RenderFieldError(row.FieldErrors, nameof(LocationSaveRequest.GridColumn))
                                                    </td>
                                                    <td>
                                                        <input type="number"
                                                               class="form-control form-control-sm"
                                                               data-testid="@($"placement-stack-level-{row.LocationId}")"
                                                               @bind="row.StackLevelText" />
                                                        @RenderFieldError(row.FieldErrors, nameof(LocationSaveRequest.StackLevel))
                                                    </td>
                                                    <td>
                                                        <input type="number"
                                                               class="form-control form-control-sm"
                                                               data-testid="@($"placement-display-order-{row.LocationId}")"
                                                               @bind="row.DisplayOrderText" />
                                                        @RenderFieldError(row.FieldErrors, nameof(LocationSaveRequest.DisplayOrder))
                                                    </td>
                                                    <td class="text-end">
                                                        <button type="button"
                                                                class="btn btn-sm btn-primary"
                                                                data-testid="@($"placement-save-{row.LocationId}")"
                                                                @onclick="@(() => SavePlacementAsync(row))">
                                                            Save
                                                        </button>
                                                    </td>
                                                </tr>

                                                @if (!string.IsNullOrWhiteSpace(row.SaveErrorMessage))
                                                {
                                                    <tr>
                                                        <td colspan="7" class="pt-0">
                                                            <div class="text-danger small" data-testid="@($"placement-save-error-{row.LocationId}")">@row.SaveErrorMessage</div>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            <div class="row g-4">
                                <section class="col-lg-7">
                                    <div class="border rounded p-3 h-100">
                                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                            <div>
                                                <h4 class="h6 mb-1">Placed Preview</h4>
                                                <p class="text-muted mb-0">Preview uses stored room-map data only.</p>
                                            </div>
                                        </div>

                                        <div data-testid="admin-placement-preview">
                                            @if (_selectedRoomMap is null || (_selectedRoomMap.PlacedLocations.Count == 0 && _selectedRoomMap.UnplacedLocations.Count == 0))
                                            {
                                                <p class="text-muted mb-0">No placed or unplaced locations are available for preview.</p>
                                            }
                                            else
                                            {
                                                <div class="mb-3" data-testid="admin-placed-preview">
                                                    @if (_selectedRoomMap.PlacedLocations.Count == 0)
                                                    {
                                                        <p class="text-muted mb-0">No placed kennels are stored for this room.</p>
                                                    }
                                                    else
                                                    {
                                                        @foreach (var cell in GetAdminPreviewCells())
                                                        {
                                                            <div class="border rounded p-2 mb-2">
                                                                <div class="small text-muted mb-1">Row @cell.Row, Column @cell.Column</div>
                                                                @foreach (var location in cell.Locations)
                                                                {
                                                                    <div class="d-flex justify-content-between gap-3">
                                                                        <span>@location.Name (@location.LocationCode.Value)</span>
                                                                        <span class="small text-muted">Stack @location.StackLevel</span>
                                                                    </div>
                                                                }
                                                            </div>
                                                        }
                                                    }
                                                </div>

                                                <div data-testid="admin-unplaced-preview">
                                                    <h4 class="h6">Unplaced Preview</h4>
                                                    @if (_selectedRoomMap.UnplacedLocations.Count == 0)
                                                    {
                                                        <p class="text-muted mb-0">No unplaced kennels are stored for this room.</p>
                                                    }
                                                    else
                                                    {
                                                        <ul class="list-group list-group-flush">
                                                            @foreach (var location in _selectedRoomMap.UnplacedLocations)
                                                            {
                                                                <li class="list-group-item px-0">
                                                                    @location.Name (@location.LocationCode.Value)
                                                                </li>
                                                            }
                                                        </ul>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </section>
                            </div>
                        </div>
                    }
                </section>
            </div>
        }
    </div>
</section>

@if (_linkDialog is not null && GetSelectedLocation() is { } selectedLinkLocation)
{
    <div class="modal d-block" tabindex="-1" role="dialog" data-testid="link-dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h2 class="h5 mb-1">@(_linkDialog.Direction == LinkDialogDirection.Outgoing ? "Add Outgoing Link" : "Add Incoming Link")</h2>
                        <p class="text-muted mb-0">@selectedLinkLocation.Name (@selectedLinkLocation.LocationCode)</p>
                    </div>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label" for="link-type-input">Link Type</label>
                        <select id="link-type-input"
                                class="form-select"
                                data-testid="link-type-input"
                                value="@_linkDialog.LinkType.ToString()"
                                @onchange="OnLinkTypeChanged">
                            @foreach (var linkType in Enum.GetValues<LinkType>())
                            {
                                <option value="@linkType">@linkType</option>
                            }
                        </select>
                        @RenderFieldError(_linkFieldErrors, nameof(LocationLinkSaveRequest.LinkType))
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="link-counterparty-input">@GetLinkCounterpartyLabel()</label>
                        <select id="link-counterparty-input"
                                class="form-select"
                                data-testid="link-counterparty-input"
                                value="@(_linkDialog.CounterpartyLocationId?.ToString() ?? string.Empty)"
                                @onchange="OnLinkCounterpartyChanged">
                            <option value="">Select a location</option>
                            @foreach (var option in GetLinkCounterpartyOptions())
                            {
                                <option value="@option.LocationId">@option.Name (@option.LocationCode) - @option.LocationType</option>
                            }
                        </select>
                        @RenderFieldError(_linkFieldErrors, GetLinkCounterpartyFieldName())
                    </div>

                    @if (LinkTypeRules.IsTopology(_linkDialog.LinkType))
                    {
                        <div class="form-check mb-3">
                            <input id="link-topology-override-input"
                                   class="form-check-input"
                                   type="checkbox"
                                   data-testid="link-topology-override-input"
                                   @bind="_linkDialog.AllowTopologyEndpointOverride" />
                            <label class="form-check-label" for="link-topology-override-input">
                                Allow unusual topology endpoints
                            </label>
                            <div class="form-text">
                                Topology links default to non-kennel spaces. This override is explicit and admin-visible.
                            </div>
                            @RenderFieldError(_linkFieldErrors, nameof(LocationLinkSaveRequest.AllowTopologyEndpointOverride))
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label" for="link-source-reference-input">Source Reference</label>
                        <input id="link-source-reference-input"
                               class="form-control"
                               data-testid="link-source-reference-input"
                               @bind="_linkDialog.SourceReference" />
                    </div>

                    <div class="mb-0">
                        <label class="form-label" for="link-notes-input">Notes</label>
                        <textarea id="link-notes-input"
                                  class="form-control"
                                  rows="3"
                                  data-testid="link-notes-input"
                                  @bind="_linkDialog.Notes"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-testid="link-cancel-button" @onclick="CloseLinkDialog">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-primary" data-testid="link-save-button" @onclick="SaveLinkAsync">
                        Save Link
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_removeLinkDialog is not null)
{
    <div class="modal d-block" tabindex="-1" role="dialog" data-testid="remove-link-dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="h5 mb-0">Remove Link</h2>
                </div>
                <div class="modal-body">
                    <p class="mb-2">
                        Remove <strong>@_removeLinkDialog.Link.LinkType</strong> between
                        <strong>@_removeLinkDialog.Link.FromLocationName</strong> and
                        <strong>@_removeLinkDialog.Link.ToLocationName</strong>?
                    </p>
                    <p class="text-muted mb-0">Remove deactivates the directed row and its reciprocal row. It does not hard-delete link history.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-testid="remove-link-cancel-button" @onclick="CloseRemoveLinkDialog">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-danger" data-testid="confirm-remove-link-button" @onclick="ConfirmRemoveLinkAsync">
                        Remove Link
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<FacilityAdminListItem> _facilities = [];
    private FacilityFormModel _facilityModel = FacilityFormModel.CreateEmpty();
    private Dictionary<string, string[]> _facilityFieldErrors = [];
    private string? _facilitySaveErrorMessage;

    private int? _selectedLocationFacilityId;
    private int? _selectedLocationId;
    private LocationAdminFacilityView? _locationView;
    private RoomMapResult? _selectedRoomMap;
    private LocationFormModel _locationModel = LocationFormModel.CreateEmpty();
    private List<RoomPlacementRowModel> _roomPlacementRows = [];
    private Dictionary<string, string[]> _locationFieldErrors = [];
    private string? _locationSaveErrorMessage;
    private string? _roomPlacementSaveErrorMessage;
    private LinkDialogModel? _linkDialog;
    private RemoveLinkDialogModel? _removeLinkDialog;
    private Dictionary<string, string[]> _linkFieldErrors = [];
    private string? _linkSaveErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        await ReloadFacilitiesAsync();
    }

    private async Task SaveFacilityAsync()
    {
        _facilityFieldErrors.Clear();
        _facilitySaveErrorMessage = null;

        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var result = await FacilityAdminService.SaveAsync(
            new FacilitySaveRequest(
                _facilityModel.FacilityId,
                _facilityModel.FacilityCode,
                _facilityModel.Name,
                _facilityModel.TimeZoneId,
                _facilityModel.IsActive,
                _facilityModel.Notes),
            authenticationState.User);

        if (result.Status == FacilitySaveStatus.Forbidden)
        {
            _facilitySaveErrorMessage = "Only admins can save facility changes.";
            return;
        }

        if (result.Status == FacilitySaveStatus.ValidationFailed)
        {
            _facilityFieldErrors = result.ValidationErrors.ToDictionary(pair => pair.Key, pair => pair.Value);
            return;
        }

        if (result.Facility is null)
        {
            return;
        }

        await ReloadFacilitiesAsync(result.Facility.FacilityId);
        SetFacilityForm(result.Facility);
        await LoadLocationFacilityAsync(result.Facility.FacilityId);
    }

    private async Task SaveLocationAsync()
    {
        _locationFieldErrors.Clear();
        _locationSaveErrorMessage = null;

        if (!_selectedLocationFacilityId.HasValue)
        {
            _locationFieldErrors[nameof(LocationSaveRequest.FacilityId)] = ["Select a facility before saving a location."];
            return;
        }

        if (!TryParseDisplayOrder(_locationModel.DisplayOrderText, out var displayOrder))
        {
            _locationFieldErrors[nameof(LocationSaveRequest.DisplayOrder)] = ["Display order must be a whole number."];
            return;
        }

        if (!TryParseOptionalWholeNumber(_locationModel.GridRowText, out var gridRow))
        {
            _locationFieldErrors[nameof(LocationSaveRequest.GridRow)] = ["Grid row must be a whole number."];
            return;
        }

        if (!TryParseOptionalWholeNumber(_locationModel.GridColumnText, out var gridColumn))
        {
            _locationFieldErrors[nameof(LocationSaveRequest.GridColumn)] = ["Grid column must be a whole number."];
            return;
        }

        if (!TryParseRequiredWholeNumber(_locationModel.StackLevelText, out var stackLevel))
        {
            _locationFieldErrors[nameof(LocationSaveRequest.StackLevel)] = ["Stack level must be a whole number."];
            return;
        }

        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        try
        {
            var result = await LocationAdminService.SaveAsync(
                new LocationSaveRequest(
                    _locationModel.LocationId,
                    _selectedLocationFacilityId.Value,
                    _locationModel.LocationType,
                    _locationModel.LocationCode,
                    _locationModel.Name,
                    _locationModel.ParentLocationId,
                    _locationModel.LocationType == LocationType.Kennel ? gridRow : null,
                    _locationModel.LocationType == LocationType.Kennel ? gridColumn : null,
                    _locationModel.LocationType == LocationType.Kennel ? stackLevel : 0,
                    displayOrder,
                    _locationModel.IsActive,
                    _locationModel.Notes),
                authenticationState.User);

            if (result.Status == LocationSaveStatus.Forbidden)
            {
                _locationSaveErrorMessage = "Only admins can save location changes.";
                return;
            }

            if (result.Status == LocationSaveStatus.ValidationFailed)
            {
                _locationFieldErrors = result.ValidationErrors.ToDictionary(pair => pair.Key, pair => pair.Value);
                return;
            }

            if (result.Location is null)
            {
                return;
            }

            await LoadLocationFacilityAsync(_selectedLocationFacilityId.Value, result.Location.LocationId);
        }
        catch (Exception)
        {
            _locationSaveErrorMessage = "The location could not be saved. Refresh the facility and try again.";
        }
    }

    private async Task ReloadFacilitiesAsync(int? preferredFacilityId = null)
    {
        _facilities = (await FacilityAdminService.ListFacilitiesAsync()).ToList();

        if (_facilities.Count == 0)
        {
            _selectedLocationFacilityId = null;
            _selectedLocationId = null;
            _locationView = null;
            _selectedRoomMap = null;
            _locationModel = LocationFormModel.CreateEmpty();
            _roomPlacementRows = [];
            ResetLinkState();
            return;
        }

        var facilityToLoad = preferredFacilityId
                             ?? _selectedLocationFacilityId
                             ?? _facilityModel.FacilityId
                             ?? _facilities[0].FacilityId;

        if (_facilities.All(x => x.FacilityId != facilityToLoad))
        {
            facilityToLoad = _facilities[0].FacilityId;
        }

        await LoadLocationFacilityAsync(facilityToLoad);
    }

    private async Task SelectFacilityAsync(FacilityAdminListItem facility)
    {
        _facilityFieldErrors.Clear();
        _facilitySaveErrorMessage = null;
        SetFacilityForm(facility);
        await LoadLocationFacilityAsync(facility.FacilityId);
    }

    private void StartCreate()
    {
        _facilityFieldErrors.Clear();
        _facilitySaveErrorMessage = null;
        _facilityModel = FacilityFormModel.CreateEmpty();
    }

    private void ResetFacilityForm()
    {
        if (_facilityModel.FacilityId.HasValue)
        {
            var selectedFacility = _facilities.Single(facility => facility.FacilityId == _facilityModel.FacilityId.Value);
            SetFacilityForm(selectedFacility);
            return;
        }

        StartCreate();
    }

    private async Task OnLocationFacilityChanged(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var facilityId))
        {
            return;
        }

        if (_facilities.SingleOrDefault(x => x.FacilityId == facilityId) is { } facility)
        {
            SetFacilityForm(facility);
        }

        await LoadLocationFacilityAsync(facilityId);
    }

    private async Task LoadLocationFacilityAsync(int facilityId, int? preferredLocationId = null)
    {
        _selectedLocationFacilityId = facilityId;
        _locationView = await LocationAdminService.GetFacilityAsync(facilityId);
        _locationFieldErrors.Clear();
        _locationSaveErrorMessage = null;
        ResetLinkState();

        if (_locationView is null)
        {
            _selectedLocationId = null;
            _selectedRoomMap = null;
            _locationModel = LocationFormModel.CreateEmpty();
            _roomPlacementRows = [];
            return;
        }

        var locationIdToSelect = preferredLocationId;
        if (!locationIdToSelect.HasValue && _selectedLocationId.HasValue && _locationView.Locations.Any(x => x.LocationId == _selectedLocationId.Value))
        {
            locationIdToSelect = _selectedLocationId.Value;
        }

        if (locationIdToSelect.HasValue && _locationView.Locations.SingleOrDefault(x => x.LocationId == locationIdToSelect.Value) is { } selectedLocation)
        {
            await SelectLocationAsync(selectedLocation.LocationId);
            return;
        }

        StartCreateLocation();
    }

    private void StartCreateLocation()
    {
        _locationFieldErrors.Clear();
        _locationSaveErrorMessage = null;
        _selectedLocationId = null;
        _selectedRoomMap = null;
        _locationModel = LocationFormModel.CreateEmpty(_selectedLocationFacilityId);
        _roomPlacementRows = [];
        ResetLinkState();
    }

    private void StartCreateChildLocation()
    {
        var selectedLocation = GetSelectedLocation();
        if (selectedLocation is null || !LocationTypeRules.CanBeContainmentParent(selectedLocation.LocationType))
        {
            return;
        }

        _locationFieldErrors.Clear();
        _locationSaveErrorMessage = null;
        _locationModel = LocationFormModel.CreateForChild(_selectedLocationFacilityId, selectedLocation.LocationId);
        ResetLinkState();
    }

    private async Task SelectLocationAsync(int locationId)
    {
        if (_locationView is null)
        {
            return;
        }

        var location = _locationView.Locations.Single(x => x.LocationId == locationId);
        _locationFieldErrors.Clear();
        _locationSaveErrorMessage = null;
        _selectedLocationId = location.LocationId;
        _locationModel = LocationFormModel.FromLocation(location);
        ResetLinkState();
        await LoadSelectedRoomPlacementAsync();
    }

    private void ResetLocationForm()
    {
        if (_selectedLocationId.HasValue && _locationView?.Locations.SingleOrDefault(x => x.LocationId == _selectedLocationId.Value) is { } location)
        {
            _locationFieldErrors.Clear();
            _locationSaveErrorMessage = null;
            _locationModel = LocationFormModel.FromLocation(location);
            ResetLinkState();
            return;
        }

        StartCreateLocation();
    }

    private void OnLocationTypeChanged(ChangeEventArgs args)
    {
        if (!Enum.TryParse<LocationType>(args.Value?.ToString(), out var locationType))
        {
            return;
        }

        _locationModel.LocationType = locationType;

        if (_locationModel.ParentLocationId.HasValue &&
            GetAvailableParentLocations().All(x => x.LocationId != _locationModel.ParentLocationId.Value))
        {
            _locationModel.ParentLocationId = null;
        }

        if (_locationModel.LocationType != LocationType.Kennel)
        {
            _locationModel.GridRowText = null;
            _locationModel.GridColumnText = null;
            _locationModel.StackLevelText = "0";
        }
    }

    private void OnParentLocationChanged(ChangeEventArgs args)
    {
        _locationModel.ParentLocationId = int.TryParse(args.Value?.ToString(), out var parentLocationId)
            ? parentLocationId
            : null;
    }

    private IReadOnlyList<LocationAdminListItem> GetAvailableParentLocations()
    {
        if (_locationView is null)
        {
            return [];
        }

        var excludedLocationIds = _locationModel.LocationId.HasValue
            ? GetDescendantLocationIds(_locationModel.LocationId.Value).Append(_locationModel.LocationId.Value).ToHashSet()
            : [];

        return _locationView.Locations
            .Where(location =>
                !excludedLocationIds.Contains(location.LocationId) &&
                LocationTypeRules.CanContainChild(location.LocationType, _locationModel.LocationType))
            .OrderBy(location => location.Name)
            .ThenBy(location => location.LocationCode)
            .ToList();
    }

    private IEnumerable<int> GetDescendantLocationIds(int locationId)
    {
        if (_locationView is null)
        {
            yield break;
        }

        var childIds = _locationView.Locations
            .Where(x => x.ParentLocationId == locationId)
            .Select(x => x.LocationId)
            .ToList();

        foreach (var childId in childIds)
        {
            yield return childId;

            foreach (var descendantId in GetDescendantLocationIds(childId))
            {
                yield return descendantId;
            }
        }
    }

    private bool CanCreateChildLocation()
    {
        var selectedLocation = GetSelectedLocation();
        return selectedLocation is not null && LocationTypeRules.CanBeContainmentParent(selectedLocation.LocationType);
    }

    private bool SelectedLocationCanManagePlacement()
    {
        var selectedLocation = GetSelectedLocation();
        return selectedLocation is not null && IsRoomLike(selectedLocation.LocationType);
    }

    private bool SelectedLocationCanManageLinks() => GetSelectedLocation() is not null;

    private LocationAdminListItem? GetSelectedLocation() =>
        _selectedLocationId.HasValue
            ? _locationView?.Locations.SingleOrDefault(x => x.LocationId == _selectedLocationId.Value)
            : null;

    private IReadOnlyList<LocationAdminLinkListItem> GetOutgoingLinks()
    {
        if (_locationView is null || !_selectedLocationId.HasValue)
        {
            return [];
        }

        return _locationView.Links
            .Where(link => link.FromLocationId == _selectedLocationId.Value)
            .OrderBy(link => link.LinkType)
            .ThenBy(link => link.ToLocationName)
            .ThenBy(link => link.ToLocationCode)
            .ToList();
    }

    private IReadOnlyList<LocationAdminLinkListItem> GetIncomingLinks()
    {
        if (_locationView is null || !_selectedLocationId.HasValue)
        {
            return [];
        }

        return _locationView.Links
            .Where(link => link.ToLocationId == _selectedLocationId.Value)
            .OrderBy(link => link.LinkType)
            .ThenBy(link => link.FromLocationName)
            .ThenBy(link => link.FromLocationCode)
            .ToList();
    }

    private void OpenCreateLinkDialog(LinkDialogDirection direction)
    {
        if (GetSelectedLocation() is null)
        {
            return;
        }

        _removeLinkDialog = null;
        _linkFieldErrors.Clear();
        _linkSaveErrorMessage = null;
        _linkDialog = new LinkDialogModel
        {
            Direction = direction
        };
    }

    private void CloseLinkDialog()
    {
        _linkDialog = null;
        _linkFieldErrors.Clear();
    }

    private void OpenRemoveLinkDialog(LocationAdminLinkListItem link)
    {
        _linkDialog = null;
        _linkFieldErrors.Clear();
        _linkSaveErrorMessage = null;
        _removeLinkDialog = new RemoveLinkDialogModel(link);
    }

    private void CloseRemoveLinkDialog()
    {
        _removeLinkDialog = null;
    }

    private void OnLinkTypeChanged(ChangeEventArgs args)
    {
        if (_linkDialog is null || !Enum.TryParse<LinkType>(args.Value?.ToString(), out var linkType))
        {
            return;
        }

        _linkDialog.LinkType = linkType;
        if (LinkTypeRules.IsAdjacency(linkType))
        {
            _linkDialog.AllowTopologyEndpointOverride = false;
        }
    }

    private void OnLinkCounterpartyChanged(ChangeEventArgs args)
    {
        if (_linkDialog is null)
        {
            return;
        }

        _linkDialog.CounterpartyLocationId = int.TryParse(args.Value?.ToString(), out var locationId)
            ? locationId
            : null;
    }

    private string GetLinkCounterpartyLabel() =>
        _linkDialog?.Direction == LinkDialogDirection.Incoming
            ? "Source location"
            : "Target location";

    private string GetLinkCounterpartyFieldName() =>
        _linkDialog?.Direction == LinkDialogDirection.Incoming
            ? nameof(LocationLinkSaveRequest.FromLocationId)
            : nameof(LocationLinkSaveRequest.ToLocationId);

    private IReadOnlyList<LocationAdminListItem> GetLinkCounterpartyOptions()
    {
        if (_locationView is null || !_selectedLocationId.HasValue)
        {
            return [];
        }

        return _locationView.Locations
            .Where(location => location.LocationId != _selectedLocationId.Value && location.IsActive)
            .OrderBy(location => location.Name)
            .ThenBy(location => location.LocationCode)
            .ToList();
    }

    private async Task SaveLinkAsync()
    {
        _linkFieldErrors.Clear();
        _linkSaveErrorMessage = null;

        var selectedLocation = GetSelectedLocation();
        if (_selectedLocationFacilityId is null || selectedLocation is null || _linkDialog is null)
        {
            _linkSaveErrorMessage = "Select a location before saving a link.";
            return;
        }

        if (!_linkDialog.CounterpartyLocationId.HasValue)
        {
            _linkFieldErrors[GetLinkCounterpartyFieldName()] = [$"{GetLinkCounterpartyLabel()} is required."];
            return;
        }

        var request = BuildLinkSaveRequest(_selectedLocationFacilityId.Value, selectedLocation.LocationId, _linkDialog);
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        try
        {
            var result = await LocationLinkAdminService.SaveAsync(request, authenticationState.User);
            if (result.Status == LocationLinkSaveStatus.Forbidden)
            {
                _linkSaveErrorMessage = "Only admins can save link changes.";
                return;
            }

            if (result.Status == LocationLinkSaveStatus.ValidationFailed)
            {
                _linkFieldErrors = result.ValidationErrors.ToDictionary(pair => pair.Key, pair => pair.Value);
                return;
            }

            _linkDialog = null;
            await LoadLocationFacilityAsync(_selectedLocationFacilityId.Value, selectedLocation.LocationId);
        }
        catch (Exception)
        {
            _linkSaveErrorMessage = "The link could not be saved. Refresh the facility and try again.";
        }
    }

    private async Task ConfirmRemoveLinkAsync()
    {
        if (_removeLinkDialog is null)
        {
            return;
        }

        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        try
        {
            var result = await LocationLinkAdminService.RemoveAsync(
                new LocationLinkRemoveRequest(
                    _removeLinkDialog.Link.FacilityId,
                    _removeLinkDialog.Link.FromLocationId,
                    _removeLinkDialog.Link.ToLocationId,
                    _removeLinkDialog.Link.LinkType),
                authenticationState.User);

            if (result.Status == LocationLinkRemoveStatus.Forbidden)
            {
                _linkSaveErrorMessage = "Only admins can remove links.";
                return;
            }

            if (result.Status == LocationLinkRemoveStatus.NotFound)
            {
                _linkSaveErrorMessage = "The selected link is no longer active.";
                _removeLinkDialog = null;
                return;
            }

            var selectedLocationId = _selectedLocationId;
            _removeLinkDialog = null;

            if (_selectedLocationFacilityId.HasValue && selectedLocationId.HasValue)
            {
                await LoadLocationFacilityAsync(_selectedLocationFacilityId.Value, selectedLocationId.Value);
            }
        }
        catch (Exception)
        {
            _linkSaveErrorMessage = "The link could not be removed. Refresh the facility and try again.";
        }
    }

    private void ResetLinkState()
    {
        _linkDialog = null;
        _removeLinkDialog = null;
        _linkFieldErrors.Clear();
        _linkSaveErrorMessage = null;
    }

    private static LocationLinkSaveRequest BuildLinkSaveRequest(int facilityId, int selectedLocationId, LinkDialogModel dialog)
    {
        var counterpartyLocationId = dialog.CounterpartyLocationId ?? 0;
        var fromLocationId = dialog.Direction == LinkDialogDirection.Outgoing ? selectedLocationId : counterpartyLocationId;
        var toLocationId = dialog.Direction == LinkDialogDirection.Outgoing ? counterpartyLocationId : selectedLocationId;

        return new LocationLinkSaveRequest(
            facilityId,
            fromLocationId,
            toLocationId,
            dialog.LinkType,
            dialog.AllowTopologyEndpointOverride,
            dialog.SourceReference,
            dialog.Notes);
    }

    private static bool TryParseDisplayOrder(string? value, out int? displayOrder)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            displayOrder = null;
            return true;
        }

        if (int.TryParse(value, out var parsedValue))
        {
            displayOrder = parsedValue;
            return true;
        }

        displayOrder = null;
        return false;
    }

    private static bool TryParseOptionalWholeNumber(string? value, out int? parsedValue)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            parsedValue = null;
            return true;
        }

        if (int.TryParse(value, out var parsed))
        {
            parsedValue = parsed;
            return true;
        }

        parsedValue = null;
        return false;
    }

    private static bool TryParseRequiredWholeNumber(string? value, out int parsedValue)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            parsedValue = 0;
            return true;
        }

        return int.TryParse(value, out parsedValue);
    }

    private async Task LoadSelectedRoomPlacementAsync()
    {
        _selectedRoomMap = null;
        _roomPlacementRows = [];
        _roomPlacementSaveErrorMessage = null;

        var selectedLocation = GetSelectedLocation();
        if (_selectedLocationFacilityId is null || selectedLocation is null || !IsRoomLike(selectedLocation.LocationType))
        {
            return;
        }

        _selectedRoomMap = await FacilityMapReadService.GetRoomMapAsync(_selectedLocationFacilityId.Value, selectedLocation.LocationId);

        if (_locationView is null)
        {
            return;
        }

        _roomPlacementRows = _locationView.Locations
            .Where(location => location.ParentLocationId == selectedLocation.LocationId && location.LocationType == LocationType.Kennel)
            .OrderBy(location => location.GridRow ?? int.MaxValue)
            .ThenBy(location => location.GridColumn ?? int.MaxValue)
            .ThenBy(location => location.StackLevel)
            .ThenBy(location => location.DisplayOrder ?? int.MaxValue)
            .ThenBy(location => location.Name)
            .ThenBy(location => location.LocationCode)
            .Select(RoomPlacementRowModel.FromLocation)
            .ToList();
    }

    private async Task SavePlacementAsync(RoomPlacementRowModel row)
    {
        row.FieldErrors.Clear();
        row.SaveErrorMessage = null;
        _roomPlacementSaveErrorMessage = null;

        var selectedRoom = GetSelectedLocation();
        if (_selectedLocationFacilityId is null || selectedRoom is null)
        {
            _roomPlacementSaveErrorMessage = "Select a room-like location before saving placement changes.";
            return;
        }

        if (!TryParseOptionalWholeNumber(row.GridRowText, out var gridRow))
        {
            row.FieldErrors[nameof(LocationSaveRequest.GridRow)] = ["Grid row must be a whole number."];
            return;
        }

        if (!TryParseOptionalWholeNumber(row.GridColumnText, out var gridColumn))
        {
            row.FieldErrors[nameof(LocationSaveRequest.GridColumn)] = ["Grid column must be a whole number."];
            return;
        }

        if (!TryParseRequiredWholeNumber(row.StackLevelText, out var stackLevel))
        {
            row.FieldErrors[nameof(LocationSaveRequest.StackLevel)] = ["Stack level must be a whole number."];
            return;
        }

        if (!TryParseDisplayOrder(row.DisplayOrderText, out var displayOrder))
        {
            row.FieldErrors[nameof(LocationSaveRequest.DisplayOrder)] = ["Display order must be a whole number."];
            return;
        }

        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var result = await LocationAdminService.SaveAsync(
            new LocationSaveRequest(
                row.LocationId,
                _selectedLocationFacilityId.Value,
                LocationType.Kennel,
                row.LocationCode,
                row.Name,
                selectedRoom.LocationId,
                gridRow,
                gridColumn,
                stackLevel,
                displayOrder,
                row.IsActive,
                row.Notes),
            authenticationState.User);

        if (result.Status == LocationSaveStatus.Forbidden)
        {
            row.SaveErrorMessage = "Only admins can save kennel placement changes.";
            return;
        }

        if (result.Status == LocationSaveStatus.ValidationFailed)
        {
            row.FieldErrors = result.ValidationErrors.ToDictionary(pair => pair.Key, pair => pair.Value);
            return;
        }

        await LoadLocationFacilityAsync(_selectedLocationFacilityId.Value, selectedRoom.LocationId);
    }

    private RenderFragment RenderFieldError(IReadOnlyDictionary<string, string[]> errors, string fieldName) => builder =>
    {
        if (!errors.TryGetValue(fieldName, out var messages))
        {
            return;
        }

        var sequence = 0;
        foreach (var message in messages)
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "text-danger small mt-1");
            builder.AddContent(sequence++, message);
            builder.CloseElement();
        }
    };

    private RenderFragment RenderLocationNode(LocationAdminTreeItem location) => builder =>
    {
        var sequence = 0;

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "mb-2");

        builder.OpenElement(sequence++, "button");
        builder.AddAttribute(sequence++, "type", "button");
        builder.AddAttribute(sequence++, "class", GetLocationListButtonCssClass(location));
        builder.AddAttribute(sequence++, "data-testid", $"location-item-{location.LocationId}");
        builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => SelectLocationAsync(location.LocationId)));

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "d-flex justify-content-between align-items-center gap-2");

        builder.OpenElement(sequence++, "span");
        builder.AddContent(sequence++, location.Name);
        builder.CloseElement();

        builder.OpenElement(sequence++, "span");
        builder.AddAttribute(sequence++, "class", "d-flex gap-1 flex-wrap");

        builder.OpenElement(sequence++, "span");
        builder.AddAttribute(sequence++, "class", "badge text-bg-light");
        builder.AddContent(sequence++, location.LocationType.ToString());
        builder.CloseElement();

        if (!location.IsActive)
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "badge text-bg-secondary");
            builder.AddContent(sequence++, "Inactive");
            builder.CloseElement();
        }

        builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "small");
        builder.AddContent(sequence++, location.LocationCode);
        builder.CloseElement();

        if (location.DisplayOrder.HasValue)
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "small text-muted");
            builder.AddContent(sequence++, $"Display order {location.DisplayOrder.Value}");
            builder.CloseElement();
        }

        builder.CloseElement();

        if (location.Children.Count > 0)
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "border-start ps-3 ms-3");

            foreach (var child in location.Children)
            {
                builder.AddContent(sequence++, RenderLocationNode(child));
            }

            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private string GetFacilityListButtonCssClass(FacilityAdminListItem facility)
    {
        const string baseCss = "list-group-item list-group-item-action text-start";
        return facility.FacilityId == _facilityModel.FacilityId
            ? $"{baseCss} active"
            : baseCss;
    }

    private string GetLocationListButtonCssClass(LocationAdminTreeItem location)
    {
        const string baseCss = "btn btn-outline-secondary w-100 text-start";
        var selectedCss = location.LocationId == _selectedLocationId ? " active" : string.Empty;
        var inactiveCss = location.IsActive ? string.Empty : " opacity-75";
        return $"{baseCss}{selectedCss}{inactiveCss}";
    }

    private void SetFacilityForm(FacilityAdminListItem facility)
    {
        _facilityFieldErrors.Clear();
        _facilitySaveErrorMessage = null;
        _facilityModel = FacilityFormModel.FromFacility(facility);
    }

    private IReadOnlyList<AdminPreviewCell> GetAdminPreviewCells()
    {
        if (_selectedRoomMap is null)
        {
            return [];
        }

        return _selectedRoomMap.PlacedLocations
            .Where(location => location.GridRow.HasValue && location.GridColumn.HasValue)
            .GroupBy(location => new { Row = location.GridRow!.Value, Column = location.GridColumn!.Value })
            .OrderBy(group => group.Key.Row)
            .ThenBy(group => group.Key.Column)
            .Select(group => new AdminPreviewCell(
                group.Key.Row,
                group.Key.Column,
                group.OrderBy(location => location.StackLevel)
                    .ThenBy(location => location.DisplayOrder ?? int.MaxValue)
                    .ThenBy(location => location.Name)
                    .ThenBy(location => location.LocationCode)
                    .ThenBy(location => location.LocationId)
                    .ToList()))
            .ToList();
    }

    private static bool IsRoomLike(LocationType locationType) =>
        locationType == LocationType.Room
        || locationType == LocationType.Medical
        || locationType == LocationType.Isolation
        || locationType == LocationType.Intake;

