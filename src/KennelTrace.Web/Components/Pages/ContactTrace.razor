@page "/trace"
@rendermode InteractiveServer
@using System.Globalization
@using KennelTrace.Domain.Common
@using KennelTrace.Domain.Features.Tracing
@using KennelTrace.Infrastructure.Features.Animals.AnimalRecords
@using KennelTrace.Infrastructure.Features.Tracing.ContactTracing
@using KennelTrace.Infrastructure.Features.Tracing.TracePage
@using KennelTrace.Web.Features.Tracing
@attribute [Authorize(Roles = $"{KennelTraceRoles.ReadOnly},{KennelTraceRoles.Admin}")]
@inject IAnimalReadService AnimalReadService
@inject IContactTraceService ContactTraceService
@inject ILogger<ContactTrace> Logger
@inject ITracePageReadService TracePageReadService

<PageTitle>Contact Trace</PageTitle>

<MudStack Spacing="3" data-testid="trace-page">
    <div>
        <MudText Typo="Typo.h4">Contact Trace</MudText>
        <MudText Typo="Typo.body1" Class="text-muted">Run one source-animal trace using persisted disease profiles, movement history, and optional location scope.</MudText>
    </div>

    @if (_isLoading)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" data-testid="trace-loading-state">
            Loading trace inputs from persisted data.
        </MudAlert>
    }
    else if (!string.IsNullOrWhiteSpace(_loadErrorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" data-testid="trace-load-error-state">
            @_loadErrorMessage
        </MudAlert>
    }
    else
    {
        <MudCard data-testid="trace-input-form">
            <MudCardContent>
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6">
                        <label class="form-label" for="trace-disease-select">Disease profile</label>
                        <select id="trace-disease-select"
                                class="form-select"
                                data-testid="trace-disease-select"
                                value="@FormatSelectedValue(_selectedDiseaseTraceProfileId)"
                                @onchange="OnDiseaseProfileChanged"
                                disabled="@(_diseaseProfiles.Count == 0 || _isRunningTrace)">
                            <option value="">Select a disease profile</option>
                            @foreach (var option in _diseaseProfiles)
                            {
                                <option value="@option.DiseaseTraceProfileId">@GetDiseaseProfileLabel(option)</option>
                            }
                        </select>
                        @RenderFieldError(nameof(ContactTraceRequest.DiseaseTraceProfileId))
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <label class="form-label" for="trace-source-animal">Source animal</label>
                        <input id="trace-source-animal"
                               class="form-control"
                               data-testid="trace-source-animal"
                               list="trace-source-animal-options"
                               placeholder="Search by animal number or name"
                               value="@(_animalSearchText ?? string.Empty)"
                               disabled="@_isRunningTrace"
                               @oninput="OnAnimalSearchChangedAsync" />
                        <datalist id="trace-source-animal-options">
                            @foreach (var animal in _animalOptions)
                            {
                                <option value="@FormatAnimalOption(animal)"></option>
                            }
                        </datalist>
                        <div class="form-text">Pick one persisted animal from the lookup suggestions.</div>
                        @RenderFieldError(nameof(ContactTraceRequest.SourceAnimalId))
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <label class="form-label" for="trace-window-start">Trace window start (UTC)</label>
                        <input id="trace-window-start"
                               class="form-control"
                               data-testid="trace-window-start"
                               type="datetime-local"
                               value="@_traceWindowStartText"
                               disabled="@_isRunningTrace"
                               @oninput="OnTraceWindowStartChanged" />
                        <div class="form-text">Enter the UTC start date and time.</div>
                        @RenderFieldError(nameof(ContactTraceRequest.TraceWindowStartUtc))
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <label class="form-label" for="trace-window-end">Trace window end (UTC)</label>
                        <input id="trace-window-end"
                               class="form-control"
                               data-testid="trace-window-end"
                               type="datetime-local"
                               value="@_traceWindowEndText"
                               disabled="@_isRunningTrace"
                               @oninput="OnTraceWindowEndChanged" />
                        <div class="form-text">Enter the UTC end date and time.</div>
                        @RenderFieldError(nameof(ContactTraceRequest.TraceWindowEndUtc))
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <label class="form-label" for="trace-scope-facility-select">Scope facility</label>
                        <select id="trace-scope-facility-select"
                                class="form-select"
                                data-testid="trace-scope-facility-select"
                                value="@FormatSelectedValue(_selectedScopeFacilityId)"
                                @onchange="OnScopeFacilityChanged"
                                disabled="@(_scopeFacilities.Count == 0 || _isRunningTrace)">
                            <option value="">All persisted scope locations</option>
                            @foreach (var facility in _scopeFacilities)
                            {
                                <option value="@facility.FacilityId">@facility.Label</option>
                            }
                        </select>
                        <div class="form-text">This only narrows the scope-location picker. It is not sent as a second trace filter.</div>
                    </MudItem>

                    <MudItem xs="12" md="8">
                        <label class="form-label" for="trace-scope-location-select">Optional location scope</label>
                        <select id="trace-scope-location-select"
                                class="form-select"
                                data-testid="trace-scope-location-select"
                                value="@FormatSelectedValue(_selectedScopeLocationId)"
                                @onchange="OnScopeLocationChanged"
                                disabled="@(FilteredScopeOptions.Count == 0 || _isRunningTrace)">
                            <option value="">No location scope</option>
                            @foreach (var option in FilteredScopeOptions)
                            {
                                <option value="@option.LocationId">@GetScopeLocationLabel(option)</option>
                            }
                        </select>
                    </MudItem>

                    <MudItem xs="12">
                        <div class="d-flex gap-2">
                            <button type="button"
                                    class="btn btn-primary"
                                    data-testid="trace-run-button"
                                    disabled="@_isRunningTrace"
                                    @onclick="RunTraceAsync">
                                @(_isRunningTrace ? "Running Trace..." : "Run Trace")
                            </button>
                        </div>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>

        @if (_diseaseProfiles.Count == 0)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" data-testid="trace-no-profiles">
                No active disease profiles are available yet.
            </MudAlert>
        }

        @if (_scopeOptions.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" data-testid="trace-no-scope-options">
                No persisted location scope options are available yet.
            </MudAlert>
        }
        else if (_selectedScopeFacilityId.HasValue && FilteredScopeOptions.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" data-testid="trace-no-scoped-facility-options">
                No persisted location scope options are available for the selected facility.
            </MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(_serviceErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" data-testid="trace-service-error-state">
                @_serviceErrorMessage
            </MudAlert>
        }

        @if (_isRunningTrace)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" data-testid="trace-running-state">
                Running contact trace against persisted movement and location data.
            </MudAlert>
        }
        else if (_lastRunSummary is null)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" data-testid="trace-idle-state">
                Select a profile, source animal, window, and optional scope, then run the trace.
            </MudAlert>
        }
        else
        {
            <MudCard data-testid="trace-success-summary">
                <MudCardContent>
                    <MudText Typo="Typo.h6">Trace summary</MudText>
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Disease profile</dt>
                        <dd class="col-sm-9">@_lastRunSummary.DiseaseProfileLabel</dd>
                        <dt class="col-sm-3">Source animal</dt>
                        <dd class="col-sm-9">@_lastRunSummary.SourceAnimalLabel</dd>
                        <dt class="col-sm-3">Window (UTC)</dt>
                        <dd class="col-sm-9">@FormatUtcWindow(_lastRunSummary.TraceWindowStartUtc, _lastRunSummary.TraceWindowEndUtc)</dd>
                        <dt class="col-sm-3">Location scope</dt>
                        <dd class="col-sm-9">@(_lastRunSummary.LocationScopeLabel ?? "No location scope")</dd>
                        <dt class="col-sm-3">Result counts</dt>
                        <dd class="col-sm-9">
                            @GetHighLevelCountsSummary(_lastRunSummary.SourceStayCount, _lastRunSummary.ImpactedLocationCount, _lastRunSummary.ImpactedAnimalCount)
                        </dd>
                    </dl>
                </MudCardContent>
            </MudCard>

            @if (_traceResult is not null && _traceResult.ImpactedLocations.Count == 0 && _traceResult.ImpactedAnimals.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" data-testid="trace-empty-state">
                    No impacted locations or animals were found for the selected trace input.
                </MudAlert>
            }

            @if (_traceResult?.UsesPartialGraphData == true)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" data-testid="trace-partial-graph-warning">
                    This trace used partial graph data; results reflect only stored relationships.
                </MudAlert>
            }

            <MudTabs Rounded="true" data-testid="trace-result-tabs">
                <MudTabPanel Text="Impacted Locations">
                    @if (_traceResult is null || _traceResult.ImpactedLocations.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" data-testid="trace-locations-empty-state">
                            No impacted locations were returned for this trace.
                        </MudAlert>
                    }
                    else
                    {
                        <MudTable Items="_traceResult.ImpactedLocations" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm" data-testid="trace-locations-table">
                            <HeaderContent>
                                <MudTh>Location</MudTh>
                                <MudTh>Match</MudTh>
                                <MudTh>Path</MudTh>
                                <MudTh>Reasons</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                @{
                                    var locationOption = GetLocationOption(context.LocationId);
                                    var scopeLocationOption = context.ScopeLocationId is null
                                        ? null
                                        : GetLocationOption(context.ScopeLocationId.Value);
                                }
                                <MudTd DataLabel="Location">
                                    <MudText Typo="Typo.body1" data-testid="@($"trace-location-name-{context.LocationId}")">
                                        @GetLocationPrimaryLabel(locationOption, context.LocationId)
                                    </MudText>
                                    <MudText Typo="Typo.body2" Class="text-muted">
                                        @GetLocationSecondaryLabel(locationOption)
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="Match">
                                    <MudText Typo="Typo.body2">@TraceResultPresenter.GetMatchLabel(context.MatchKind)</MudText>
                                    @if (scopeLocationOption is not null)
                                    {
                                        <MudText Typo="Typo.body2" Class="text-muted" data-testid="@($"trace-location-scope-{context.LocationId}")">
                                            Scoped by @GetLocationPrimaryLabel(scopeLocationOption, scopeLocationOption.LocationId)
                                        </MudText>
                                    }
                                </MudTd>
                                <MudTd DataLabel="Path">
                                    <MudText Typo="Typo.body2">
                                        @(context.TraversalDepth == 0 ? "Direct match" : $"Depth {context.TraversalDepth}")
                                    </MudText>
                                    @if (context.ViaLinkType is not null)
                                    {
                                        <MudText Typo="Typo.body2" Class="text-muted">
                                            @TraceResultPresenter.GetLinkLabel(context.ViaLinkType)
                                        </MudText>
                                    }
                                </MudTd>
                                <MudTd DataLabel="Reasons">
                                    <MudChipSet T="string">
                                        @foreach (var reasonCode in context.ReasonCodes)
                                        {
                                            <MudChip T="string"
                                                     Size="Size.Small"
                                                     Variant="Variant.Outlined"
                                                     data-testid="@($"trace-location-reason-{context.LocationId}-{reasonCode}")">
                                                @TraceResultPresenter.GetReasonLabel(reasonCode)
                                            </MudChip>
                                        }
                                    </MudChipSet>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudTabPanel>
                <MudTabPanel Text="Impacted Animals">
                    @if (_traceResult is null || _traceResult.ImpactedAnimals.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" data-testid="trace-animals-empty-state">
                            No impacted animals were returned for this trace.
                        </MudAlert>
                    }
                    else
                    {
                        <MudTable Items="_traceResult.ImpactedAnimals" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm" data-testid="trace-animals-table">
                            <HeaderContent>
                                <MudTh>Animal</MudTh>
                                <MudTh>Impacted location</MudTh>
                                <MudTh>Overlap context</MudTh>
                                <MudTh>Reasons</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                @{
                                    var impactedLocationOption = GetLocationOption(context.ImpactedLocationId);
                                }
                                <MudTd DataLabel="Animal">
                                    <MudLink Href="@($"/animals/{context.AnimalId}")"
                                             data-testid="@($"trace-animal-link-{context.AnimalId}")">
                                        @GetAnimalPrimaryLabel(context)
                                    </MudLink>
                                    <MudText Typo="Typo.body2" Class="text-muted">
                                        @context.AnimalNumber.Value
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="Impacted location">
                                    <MudText Typo="Typo.body2" data-testid="@($"trace-animal-location-{context.AnimalId}")">
                                        @GetLocationPrimaryLabel(impactedLocationOption, context.ImpactedLocationId)
                                    </MudText>
                                    <MudText Typo="Typo.body2" Class="text-muted">
                                        @GetLocationSecondaryLabel(impactedLocationOption)
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="Overlap context">
                                    @foreach (var overlap in context.OverlappingStays)
                                    {
                                        var overlapLocationOption = GetLocationOption(overlap.StayLocationId);
                                        <div class="mb-1" data-testid="@($"trace-animal-overlap-{context.AnimalId}-{overlap.OverlappingStayId}")">
                                            <MudText Typo="Typo.body2">
                                                @($"{TraceResultPresenter.FormatUtc(overlap.OverlapStartUtc)} to {TraceResultPresenter.FormatUtc(overlap.OverlapEndUtc)}")
                                            </MudText>
                                            <MudText Typo="Typo.body2" Class="text-muted">
                                                @($"{GetLocationPrimaryLabel(overlapLocationOption, overlap.StayLocationId)} stay {TraceResultPresenter.FormatUtc(overlap.StayStartUtc)} to {TraceResultPresenter.FormatUtc(overlap.StayEndUtc)}")
                                            </MudText>
                                        </div>
                                    }
                                </MudTd>
                                <MudTd DataLabel="Reasons">
                                    <MudChipSet T="string">
                                        @foreach (var reasonCode in context.ReasonCodes)
                                        {
                                            <MudChip T="string"
                                                     Size="Size.Small"
                                                     Variant="Variant.Outlined"
                                                     data-testid="@($"trace-animal-reason-{context.AnimalId}-{reasonCode}")">
                                                @TraceResultPresenter.GetReasonLabel(reasonCode)
                                            </MudChip>
                                        }
                                    </MudChipSet>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudTabPanel>
                <MudTabPanel Text="Why Included">
                    @{
                        var whyIncludedRows = GetWhyIncludedRows();
                    }
                    @if (whyIncludedRows.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" data-testid="trace-why-included-empty-state">
                            No explainability details are available because this trace returned no impacted locations or animals.
                        </MudAlert>
                    }
                    else
                    {
                        <MudTable Items="whyIncludedRows" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm" data-testid="trace-why-included-table">
                            <HeaderContent>
                                <MudTh>Included</MudTh>
                                <MudTh>Reason</MudTh>
                                <MudTh>Why</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Included">
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Variant="Variant.Outlined"
                                             Class="mb-1">
                                        @context.SubjectKindLabel
                                    </MudChip>
                                    <MudText Typo="Typo.body1" data-testid="@($"trace-why-included-subject-{context.TestId}")">
                                        @context.SubjectPrimaryLabel
                                    </MudText>
                                    <MudText Typo="Typo.body2" Class="text-muted">
                                        @context.SubjectSecondaryLabel
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="Reason">
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Variant="Variant.Outlined"
                                             data-testid="@($"trace-why-included-reason-{context.TestId}")">
                                        @context.ReasonLabel
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="Why">
                                    <MudText Typo="Typo.body2" data-testid="@($"trace-why-included-explanation-{context.TestId}")">
                                        @context.Explanation
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudTabPanel>
            </MudTabs>
        }
    }
</MudStack>

@code {
    private IReadOnlyList<TraceDiseaseProfileOption> _diseaseProfiles = [];
    private IReadOnlyList<TraceLocationScopeOption> _scopeOptions = [];
    private IReadOnlyList<ScopeFacilityOption> _scopeFacilities = [];
    private bool _isLoading = true;
    private bool _isRunningTrace;
    private int? _selectedDiseaseTraceProfileId;
    private int? _selectedScopeFacilityId;
    private int? _selectedScopeLocationId;
    private AnimalLookupRow? _selectedAnimal;
    private string? _animalSearchText;
    private IReadOnlyList<AnimalLookupRow> _animalOptions = [];
    private readonly Dictionary<string, string[]> _fieldErrors = [];
    private string? _traceWindowStartText;
    private string? _traceWindowEndText;
    private bool _windowWasManuallyEdited;
    private string? _loadErrorMessage;
    private string? _serviceErrorMessage;
    private ContactTraceResult? _traceResult;
    private TraceRunSummary? _lastRunSummary;
    private Dictionary<int, TraceLocationScopeOption> _locationOptionsById = [];

    private IReadOnlyList<TraceLocationScopeOption> FilteredScopeOptions =>
        _selectedScopeFacilityId is null
            ? _scopeOptions
            : _scopeOptions.Where(x => x.FacilityId == _selectedScopeFacilityId.Value).ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var diseaseProfilesTask = TracePageReadService.ListActiveDiseaseProfilesAsync();
            var scopeOptionsTask = TracePageReadService.ListLocationScopeOptionsAsync();

            await Task.WhenAll(diseaseProfilesTask, scopeOptionsTask);

            _diseaseProfiles = diseaseProfilesTask.Result;
            _scopeOptions = scopeOptionsTask.Result;
            _scopeFacilities = _scopeOptions
                .Select(x => new ScopeFacilityOption(x.FacilityId, $"{x.FacilityName} ({x.FacilityCode.Value})"))
                .DistinctBy(x => x.FacilityId)
                .OrderBy(x => x.Label, StringComparer.OrdinalIgnoreCase)
                .ToList();
            _locationOptionsById = _scopeOptions
                .GroupBy(x => x.LocationId)
                .ToDictionary(x => x.Key, x => x.First());
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to load trace input options.");
            _loadErrorMessage = "Trace inputs could not be loaded from persisted data.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnAnimalSearchChangedAsync(ChangeEventArgs args)
    {
        ClearSubmitFeedback();
        _animalSearchText = args.Value?.ToString();

        if (string.IsNullOrWhiteSpace(_animalSearchText))
        {
            _animalOptions = [];
            _selectedAnimal = null;
            return;
        }

        _animalOptions = await AnimalReadService.LookupAnimalsAsync(_animalSearchText);
        _selectedAnimal = ResolveSelectedAnimal(_animalSearchText, _animalOptions);
    }

    private Task OnDiseaseProfileChanged(ChangeEventArgs args)
    {
        ClearSubmitFeedback();
        _selectedDiseaseTraceProfileId = ParseNullableInt(args.Value);
        ApplyProfileWindowDefaultsIfNeeded();
        return Task.CompletedTask;
    }

    private Task OnScopeFacilityChanged(ChangeEventArgs args)
    {
        ClearSubmitFeedback();
        _selectedScopeFacilityId = ParseNullableInt(args.Value);
        _selectedScopeLocationId = null;
        return Task.CompletedTask;
    }

    private Task OnScopeLocationChanged(ChangeEventArgs args)
    {
        ClearSubmitFeedback();
        _selectedScopeLocationId = ParseNullableInt(args.Value);
        return Task.CompletedTask;
    }

    private Task OnTraceWindowStartChanged(ChangeEventArgs args)
    {
        ClearSubmitFeedback();
        _traceWindowStartText = args.Value?.ToString();
        _windowWasManuallyEdited = true;
        return Task.CompletedTask;
    }

    private Task OnTraceWindowEndChanged(ChangeEventArgs args)
    {
        ClearSubmitFeedback();
        _traceWindowEndText = args.Value?.ToString();
        _windowWasManuallyEdited = true;
        return Task.CompletedTask;
    }

    private async Task RunTraceAsync()
    {
        ClearSubmitFeedback();
        _traceResult = null;
        _lastRunSummary = null;

        if (!TryBuildRequest(out var request, out var traceWindowStartUtc, out var traceWindowEndUtc))
        {
            return;
        }

        _isRunningTrace = true;

        try
        {
            var result = await ContactTraceService.RunAsync(request);
            var selectedProfile = _diseaseProfiles.Single(x => x.DiseaseTraceProfileId == request.DiseaseTraceProfileId);
            var selectedScope = _selectedScopeLocationId is null
                ? null
                : _scopeOptions.FirstOrDefault(x => x.LocationId == _selectedScopeLocationId.Value);

            _traceResult = result;
            _lastRunSummary = new TraceRunSummary(
                GetDiseaseProfileLabel(selectedProfile),
                FormatAnimalOption(_selectedAnimal) ?? "Unknown source animal",
                traceWindowStartUtc,
                traceWindowEndUtc,
                selectedScope is null ? null : GetScopeLocationLabel(selectedScope),
                result.SourceStayIds.Count,
                result.ImpactedLocations.Count,
                result.ImpactedAnimals.Count);
        }
        catch (DomainValidationException exception)
        {
            _serviceErrorMessage = exception.Message;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Contact trace execution failed.");
            _serviceErrorMessage = "The contact trace could not be completed. Review the input and try again.";
        }
        finally
        {
            _isRunningTrace = false;
        }
    }

    private bool TryBuildRequest(
        out ContactTraceRequest request,
        out DateTime traceWindowStartUtc,
        out DateTime traceWindowEndUtc)
    {
        request = null!;
        traceWindowStartUtc = default;
        traceWindowEndUtc = default;

        if (_selectedDiseaseTraceProfileId is null)
        {
            _fieldErrors[nameof(ContactTraceRequest.DiseaseTraceProfileId)] = ["Select a disease profile before running a trace."];
        }

        if (_selectedAnimal is null)
        {
            _fieldErrors[nameof(ContactTraceRequest.SourceAnimalId)] = ["Select a persisted source animal before running a trace."];
        }

        if (!TryParseUtcDateTime(_traceWindowStartText, out traceWindowStartUtc))
        {
            _fieldErrors[nameof(ContactTraceRequest.TraceWindowStartUtc)] = ["Trace window start must be a valid UTC date and time."];
        }

        if (!TryParseUtcDateTime(_traceWindowEndText, out traceWindowEndUtc))
        {
            _fieldErrors[nameof(ContactTraceRequest.TraceWindowEndUtc)] = ["Trace window end must be a valid UTC date and time."];
        }

        if (_fieldErrors.Count > 0)
        {
            return false;
        }

        if (traceWindowEndUtc <= traceWindowStartUtc)
        {
            _fieldErrors[nameof(ContactTraceRequest.TraceWindowEndUtc)] = ["Trace window end must be later than the trace window start."];
            return false;
        }

        request = new ContactTraceRequest(
            _selectedDiseaseTraceProfileId!.Value,
            traceWindowStartUtc,
            traceWindowEndUtc,
            sourceAnimalId: _selectedAnimal!.AnimalId,
            sourceStayId: null,
            facilityId: null,
            locationScopeLocationId: _selectedScopeLocationId);
        return true;
    }

    private void ApplyProfileWindowDefaultsIfNeeded()
    {
        if (_windowWasManuallyEdited || _selectedDiseaseTraceProfileId is null)
        {
            return;
        }

        var selectedProfile = _diseaseProfiles.FirstOrDefault(x => x.DiseaseTraceProfileId == _selectedDiseaseTraceProfileId.Value);
        if (selectedProfile is null)
        {
            return;
        }

        var windowEndUtc = TruncateToMinute(DateTime.UtcNow);
        var windowStartUtc = windowEndUtc.AddHours(-selectedProfile.DefaultLookbackHours);
        _traceWindowStartText = FormatDateTimeLocal(windowStartUtc);
        _traceWindowEndText = FormatDateTimeLocal(windowEndUtc);
    }

    private void ClearSubmitFeedback()
    {
        _fieldErrors.Clear();
        _serviceErrorMessage = null;
    }

    private static string GetDiseaseProfileLabel(TraceDiseaseProfileOption option) =>
        $"{option.DiseaseName} ({option.DiseaseCode.Value})";

    private static string GetScopeLocationLabel(TraceLocationScopeOption option) =>
        $"{option.LocationName} ({option.LocationCode.Value}) - {option.LocationType}";

    private static string? FormatAnimalOption(AnimalLookupRow? option) =>
        option is null
            ? null
            : string.IsNullOrWhiteSpace(option.Name)
                ? option.AnimalNumber.Value
                : $"{option.AnimalNumber.Value} - {option.Name}";

    private static AnimalLookupRow? ResolveSelectedAnimal(string? input, IEnumerable<AnimalLookupRow> options)
    {
        if (string.IsNullOrWhiteSpace(input))
        {
            return null;
        }

        return options.FirstOrDefault(option =>
            string.Equals(FormatAnimalOption(option), input, StringComparison.OrdinalIgnoreCase)
            || string.Equals(option.AnimalNumber.Value, input, StringComparison.OrdinalIgnoreCase)
            || string.Equals(option.Name, input, StringComparison.OrdinalIgnoreCase));
    }

    private static string FormatSelectedValue(int? value) => value?.ToString() ?? string.Empty;

    private static int? ParseNullableInt(object? value) =>
        int.TryParse(value?.ToString(), out var parsedValue)
            ? parsedValue
            : null;

    private static string FormatDateTimeLocal(DateTime value) =>
        value.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture);

    private static bool TryParseUtcDateTime(string? value, out DateTime parsedValue)
    {
        if (DateTime.TryParseExact(value, "yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
        {
            parsedValue = DateTime.SpecifyKind(parsed, DateTimeKind.Utc);
            return true;
        }

        parsedValue = default;
        return false;
    }

    private static DateTime TruncateToMinute(DateTime value) =>
        new(value.Year, value.Month, value.Day, value.Hour, value.Minute, 0, DateTimeKind.Utc);

    private static string FormatUtcWindow(DateTime startUtc, DateTime endUtc) =>
        $"{FormatUtc(startUtc)} to {FormatUtc(endUtc)}";

    private static string FormatUtc(DateTime value) =>
        TraceResultPresenter.FormatUtc(value);

    private static string GetHighLevelCountsSummary(int sourceStayCount, int impactedLocationCount, int impactedAnimalCount) =>
        $"{sourceStayCount} source stay(s), {impactedLocationCount} impacted location(s), {impactedAnimalCount} impacted animal(s).";

    private TraceLocationScopeOption? GetLocationOption(int locationId) =>
        _locationOptionsById.GetValueOrDefault(locationId);

    private static string GetLocationPrimaryLabel(TraceLocationScopeOption? locationOption, int locationId) =>
        locationOption is null
            ? $"Location #{locationId}"
            : $"{locationOption.LocationName} ({locationOption.LocationCode.Value})";

    private static string GetLocationSecondaryLabel(TraceLocationScopeOption? locationOption) =>
        locationOption is null
            ? "Persisted location details were not available on the trace page."
            : $"{locationOption.LocationType} in {locationOption.FacilityName} ({locationOption.FacilityCode.Value})";

    private static string GetAnimalPrimaryLabel(ImpactedAnimalResult animal) =>
        string.IsNullOrWhiteSpace(animal.AnimalName)
            ? animal.AnimalNumber.Value
            : $"{animal.AnimalNumber.Value} - {animal.AnimalName}";

    private IReadOnlyList<TraceWhyIncludedRow> GetWhyIncludedRows()
    {
        if (_traceResult is null)
        {
            return [];
        }

        return _traceResult.ImpactedLocations
            .SelectMany(BuildLocationWhyIncludedRows)
            .Concat(_traceResult.ImpactedAnimals.SelectMany(BuildAnimalWhyIncludedRows))
            .OrderBy(x => x.SubjectSortOrder)
            .ThenBy(x => x.SubjectPrimaryLabel, StringComparer.OrdinalIgnoreCase)
            .ThenBy(x => x.ReasonLabel, StringComparer.OrdinalIgnoreCase)
            .ThenBy(x => x.TestId, StringComparer.Ordinal)
            .ToArray();
    }

    private IReadOnlyList<TraceWhyIncludedRow> BuildLocationWhyIncludedRows(ImpactedLocationResult location)
    {
        var locationOption = GetLocationOption(location.LocationId);
        var impactedLocationLabel = GetLocationPrimaryLabel(locationOption, location.LocationId);
        var subjectSecondaryLabel = GetLocationSecondaryLabel(locationOption);

        if (location.Reasons.Count > 0)
        {
            return location.Reasons
                .Select(reason => CreateLocationWhyIncludedRow(
                    location.LocationId,
                    impactedLocationLabel,
                    subjectSecondaryLabel,
                    reason))
                .ToArray();
        }

        return location.ReasonCodes
            .Select(reasonCode => new TraceWhyIncludedRow(
                SubjectKindLabel: "Location",
                SubjectSortOrder: 0,
                SubjectPrimaryLabel: impactedLocationLabel,
                SubjectSecondaryLabel: subjectSecondaryLabel,
                ReasonLabel: TraceResultPresenter.GetReasonLabel(reasonCode),
                Explanation: TraceResultPresenter.GetFallbackLocationReasonExplanation(reasonCode, impactedLocationLabel),
                TestId: BuildWhyIncludedTestId("location", location.LocationId, reasonCode)))
            .ToArray();
    }

    private TraceWhyIncludedRow CreateLocationWhyIncludedRow(
        int locationId,
        string impactedLocationLabel,
        string subjectSecondaryLabel,
        ImpactedLocationReason reason)
    {
        var sourceLocationLabel = GetLocationPrimaryLabel(GetLocationOption(reason.SourceLocationId), reason.SourceLocationId);
        var scopeLocationLabel = reason.ScopeLocationId is null
            ? null
            : GetLocationPrimaryLabel(GetLocationOption(reason.ScopeLocationId.Value), reason.ScopeLocationId.Value);

        return new TraceWhyIncludedRow(
            SubjectKindLabel: "Location",
            SubjectSortOrder: 0,
            SubjectPrimaryLabel: impactedLocationLabel,
            SubjectSecondaryLabel: subjectSecondaryLabel,
            ReasonLabel: TraceResultPresenter.GetReasonLabel(reason.ReasonCode),
            Explanation: TraceResultPresenter.GetLocationReasonExplanation(
                reason,
                impactedLocationLabel,
                sourceLocationLabel,
                scopeLocationLabel),
            TestId: BuildWhyIncludedTestId("location", locationId, reason.ReasonCode, reason.SourceStayId));
    }

    private IReadOnlyList<TraceWhyIncludedRow> BuildAnimalWhyIncludedRows(ImpactedAnimalResult animal)
    {
        var impactedLocationOption = GetLocationOption(animal.ImpactedLocationId);
        var impactedLocationLabel = GetLocationPrimaryLabel(impactedLocationOption, animal.ImpactedLocationId);
        var subjectPrimaryLabel = GetAnimalPrimaryLabel(animal);
        var subjectSecondaryLabel = GetAnimalWhyIncludedSecondaryLabel(impactedLocationLabel, animal.OverlappingStays.Count);

        return animal.Reasons.Count > 0
            ? animal.Reasons
                .Select(reason => CreateAnimalWhyIncludedRow(
                    animal.AnimalId,
                    subjectPrimaryLabel,
                    subjectSecondaryLabel,
                    impactedLocationLabel,
                    reason))
                .ToArray()
            : animal.ReasonCodes
                .Select(reasonCode => new TraceWhyIncludedRow(
                    SubjectKindLabel: "Animal",
                    SubjectSortOrder: 1,
                    SubjectPrimaryLabel: subjectPrimaryLabel,
                    SubjectSecondaryLabel: subjectSecondaryLabel,
                    ReasonLabel: TraceResultPresenter.GetReasonLabel(reasonCode),
                    Explanation: TraceResultPresenter.GetFallbackAnimalReasonExplanation(reasonCode, impactedLocationLabel),
                    TestId: BuildWhyIncludedTestId("animal", animal.AnimalId, reasonCode)))
                .ToArray();
    }

    private TraceWhyIncludedRow CreateAnimalWhyIncludedRow(
        int animalId,
        string subjectPrimaryLabel,
        string subjectSecondaryLabel,
        string impactedLocationLabel,
        ImpactedLocationReason reason)
    {
        var sourceLocationLabel = GetLocationPrimaryLabel(GetLocationOption(reason.SourceLocationId), reason.SourceLocationId);
        var scopeLocationLabel = reason.ScopeLocationId is null
            ? null
            : GetLocationPrimaryLabel(GetLocationOption(reason.ScopeLocationId.Value), reason.ScopeLocationId.Value);

        return new TraceWhyIncludedRow(
            SubjectKindLabel: "Animal",
            SubjectSortOrder: 1,
            SubjectPrimaryLabel: subjectPrimaryLabel,
            SubjectSecondaryLabel: subjectSecondaryLabel,
            ReasonLabel: TraceResultPresenter.GetReasonLabel(reason.ReasonCode),
            Explanation: TraceResultPresenter.GetAnimalReasonExplanation(
                reason,
                impactedLocationLabel,
                sourceLocationLabel,
                scopeLocationLabel),
            TestId: BuildWhyIncludedTestId("animal", animalId, reason.ReasonCode, reason.SourceStayId));
    }

    private static string GetAnimalWhyIncludedSecondaryLabel(string impactedLocationLabel, int overlappingStayCount) =>
        $"Impacted at {impactedLocationLabel}. {overlappingStayCount} overlapping stay(s) matched this trace window.";

    private static string BuildWhyIncludedTestId(
        string subjectPrefix,
        int subjectId,
        TraceReasonCode reasonCode,
        long? sourceStayId = null) =>
        $"{subjectPrefix}-{subjectId}-{reasonCode}-{sourceStayId ?? 0}";

    private RenderFragment RenderFieldError(string fieldName) => builder =>
    {
        if (!_fieldErrors.TryGetValue(fieldName, out var messages))
        {
            return;
        }

        var sequence = 0;
        foreach (var message in messages)
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "text-danger small mt-1");
            builder.AddContent(sequence++, message);
            builder.CloseElement();
        }
    };

    private sealed record ScopeFacilityOption(int FacilityId, string Label);

    private sealed record TraceRunSummary(
        string DiseaseProfileLabel,
        string SourceAnimalLabel,
        DateTime TraceWindowStartUtc,
        DateTime TraceWindowEndUtc,
        string? LocationScopeLabel,
        int SourceStayCount,
        int ImpactedLocationCount,
        int ImpactedAnimalCount);

    private sealed record TraceWhyIncludedRow(
        string SubjectKindLabel,
        int SubjectSortOrder,
        string SubjectPrimaryLabel,
        string SubjectSecondaryLabel,
        string ReasonLabel,
        string Explanation,
        string TestId);
}
