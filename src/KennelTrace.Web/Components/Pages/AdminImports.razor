@page "/admin/imports"
@rendermode InteractiveServer
@using System.Security.Claims
@using KennelTrace.Domain.Features.Imports
@using KennelTrace.Web.Features.Imports.Admin
@using KennelTrace.Web.Security
@using Microsoft.AspNetCore.Components.Forms
@attribute [Authorize(Roles = KennelTraceRoles.Admin)]
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IImportAdminHistoryReadService ImportAdminHistoryReadService
@inject IImportAdminService ImportAdminService

<PageTitle>Admin Imports</PageTitle>

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 data-testid="admin-imports-page">Admin Imports</h1>
        <p class="text-muted mb-0">Upload one canonical workbook, run validate-only, review row-level issues, and inspect recent persisted import history.</p>
    </div>
</div>

<section class="card shadow-sm mb-4">
    <div class="card-header">
        <h2 class="h5 mb-0">Validate Canonical Workbook</h2>
    </div>
    <div class="card-body">
        <div class="alert alert-secondary" role="note" data-testid="import-format-hint">
            Canonical workbook format for this slice: required sheets <code>Rooms</code>, <code>Kennels</code>, and <code>LocationLinks</code>; optional sheet <code>Facilities</code>.
        </div>

        @if (!string.IsNullOrWhiteSpace(_submitErrorMessage))
        {
            <div class="alert alert-danger" role="alert" data-testid="import-submit-error">@_submitErrorMessage</div>
        }

        <div class="mb-3">
            <label class="form-label" for="import-workbook-input">Workbook</label>
            <InputFile id="import-workbook-input"
                       OnChange="OnWorkbookSelected"
                       accept=".xlsx"
                       class="form-control"
                       data-testid="import-workbook-input" />
            <div class="form-text">Only one canonical <code>.xlsx</code> workbook is accepted for this validate-only admin flow.</div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_selectedFileName))
        {
            <div class="small text-muted mb-3" data-testid="selected-workbook-name">Selected workbook: @_selectedFileName</div>
        }

        <button type="button"
                class="btn btn-primary"
                data-testid="validate-only-button"
                disabled="@_isRunning"
                @onclick="RunValidateOnlyAsync">
            @(_isRunning ? "Validating..." : "Validate only")
        </button>
    </div>
</section>

<section class="card shadow-sm mb-4">
    <div class="card-header">
        <h2 class="h5 mb-0">Latest Validate-Only Result</h2>
    </div>
    <div class="card-body">
        @if (_lastRun is null)
        {
            <div class="alert alert-info mb-0" role="status" data-testid="latest-import-empty-state">
                No validate-only workbook run has been started from this page yet.
            </div>
        }
        else
        {
            <div class="table-responsive mb-4">
                <table class="table table-sm align-middle mb-0" data-testid="latest-import-summary">
                    <tbody>
                        <tr>
                            <th scope="row">File name</th>
                            <td>@_lastRun.Batch!.SourceFileName</td>
                            <th scope="row">Run mode</th>
                            <td>@_lastRun.Batch.RunMode</td>
                        </tr>
                        <tr>
                            <th scope="row">Status</th>
                            <td>@_lastRun.Batch.Status</td>
                            <th scope="row">Facility</th>
                            <td>@(_lastRun.ResolvedFacilityDisplay ?? "Not resolved")</td>
                        </tr>
                        <tr>
                            <th scope="row">Started UTC</th>
                            <td>@FormatUtc(_lastRun.Batch.StartedUtc)</td>
                            <th scope="row">Completed UTC</th>
                            <td>@FormatUtc(_lastRun.Batch.CompletedUtc)</td>
                        </tr>
                        <tr>
                            <th scope="row">Errors</th>
                            <td>@_lastRun.Batch.ErrorCount</td>
                            <th scope="row">Warnings</th>
                            <td>@_lastRun.Batch.WarningCount</td>
                        </tr>
                        <tr>
                            <th scope="row">Summary</th>
                            <td colspan="3">@(_lastRun.Batch.Summary ?? "No summary text was recorded.")</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <h3 class="h6">Row-Level Issues</h3>

            @if (_lastRun.Batch.Issues.Count == 0)
            {
                <div class="alert alert-info mb-0" role="status" data-testid="latest-import-issues-empty-state">
                    No row-level issues were recorded for this validate-only run.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-sm align-middle" data-testid="latest-import-issues-table">
                        <thead>
                            <tr>
                                <th scope="col">Severity</th>
                                <th scope="col">Sheet</th>
                                <th scope="col">Row</th>
                                <th scope="col">Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var issue in _lastRun.Batch.Issues)
                            {
                                <tr data-testid="@($"latest-import-issue-{issue.ImportIssueId}")">
                                    <td>@issue.Severity</td>
                                    <td>@issue.SheetName</td>
                                    <td>@(issue.RowNumber?.ToString() ?? "n/a")</td>
                                    <td>@issue.Message</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    </div>
</section>

<section class="card shadow-sm">
    <div class="card-header">
        <h2 class="h5 mb-0">Recent Import History</h2>
    </div>
    <div class="card-body">
        @if (_recentBatches.Count == 0)
        {
            <div class="alert alert-info mb-0" role="status" data-testid="import-history-empty-state">
                No persisted import batches are available yet. Run validate-only on a canonical workbook to create the first audit entry.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-sm align-middle" data-testid="import-history-table">
                    <thead>
                        <tr>
                            <th scope="col">Started UTC</th>
                            <th scope="col">Completed UTC</th>
                            <th scope="col">File</th>
                            <th scope="col">Run mode</th>
                            <th scope="col">Status</th>
                            <th scope="col">Facility</th>
                            <th scope="col">Summary</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var batch in _recentBatches)
                        {
                            <tr data-testid="@($"import-history-row-{batch.ImportBatchId}")">
                                <td>@FormatUtc(batch.StartedUtc)</td>
                                <td>@FormatUtc(batch.CompletedUtc)</td>
                                <td>@batch.SourceFileName</td>
                                <td>@batch.RunMode</td>
                                <td>@batch.Status</td>
                                <td>@(batch.FacilityDisplay ?? "Not resolved")</td>
                                <td>@(batch.Summary ?? "No summary text was recorded.")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

@code {
    private const long MaxWorkbookBytes = 5 * 1024 * 1024;

    private IBrowserFile? _selectedWorkbook;
    private string? _selectedFileName;
    private string? _submitErrorMessage;
    private bool _isRunning;
    private ImportAdminRunResult? _lastRun;
    private IReadOnlyList<ImportBatchListItemView> _recentBatches = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadRecentBatchesAsync();
    }

    private async Task OnWorkbookSelected(InputFileChangeEventArgs args)
    {
        _submitErrorMessage = null;
        _selectedWorkbook = args.File;
        _selectedFileName = _selectedWorkbook.Name;

        if (!HasWorkbookExtension(_selectedFileName))
        {
            _submitErrorMessage = "Only canonical .xlsx workbooks are supported for this admin validate-only flow.";
            _selectedWorkbook = null;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task RunValidateOnlyAsync()
    {
        _submitErrorMessage = null;

        if (_selectedWorkbook is null || string.IsNullOrWhiteSpace(_selectedFileName))
        {
            _submitErrorMessage = "Select one canonical .xlsx workbook before running validate only.";
            return;
        }

        if (!HasWorkbookExtension(_selectedFileName))
        {
            _submitErrorMessage = "Only canonical .xlsx workbooks are supported for this admin validate-only flow.";
            return;
        }

        _isRunning = true;

        try
        {
            await using var workbookStream = _selectedWorkbook.OpenReadStream(MaxWorkbookBytes);
            var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var result = await ImportAdminService.ValidateAsync(
                new ImportAdminValidateRequest(
                    workbookStream,
                    _selectedFileName,
                    ResolveExecutedByUserId(authenticationState.User)),
                authenticationState.User);

            if (result.Status == ImportAdminRunStatus.Forbidden)
            {
                _submitErrorMessage = "Only admins can run workbook imports.";
                return;
            }

            if (result.Status == ImportAdminRunStatus.Failed)
            {
                _submitErrorMessage = result.ErrorMessage ?? "The workbook could not be validated.";
                return;
            }

            _lastRun = result;
            await LoadRecentBatchesAsync();
        }
        catch (IOException)
        {
            _submitErrorMessage = $"The selected workbook exceeds the {MaxWorkbookBytes / (1024 * 1024)} MB upload limit for this admin slice.";
        }
        catch (InvalidDataException)
        {
            _submitErrorMessage = "The selected file is not a readable .xlsx workbook.";
        }
        catch (Exception)
        {
            _submitErrorMessage = "The workbook could not be validated. Refresh the page and try again.";
        }
        finally
        {
            _isRunning = false;
        }
    }

    private async Task LoadRecentBatchesAsync()
    {
        _recentBatches = await ImportAdminHistoryReadService.ListRecentBatchesAsync();
    }

    private static bool HasWorkbookExtension(string fileName) =>
        fileName.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase);

    private static string? ResolveExecutedByUserId(ClaimsPrincipal user) =>
        user.FindFirst(ClaimTypes.NameIdentifier)?.Value
        ?? user.FindFirst(ClaimTypes.Name)?.Value;

    private static string FormatUtc(DateTime? value) =>
        value.HasValue ? value.Value.ToString("yyyy-MM-dd HH:mm:ss 'UTC'") : "n/a";
}
